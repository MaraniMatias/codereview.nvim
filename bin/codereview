#!/bin/bash
# codereview - git difftool wrapper for codereview.nvim
#
# Configure in ~/.gitconfig:
#   [difftool "codereview"]
#       cmd = /path/to/codereview/bin/codereview "$LOCAL" "$REMOTE"
#   [difftool]
#       prompt = false
#
# Usage:
#   git difftool --dir-diff -t codereview
#   git difftool --dir-diff --cached -t codereview
#   git difftool --dir-diff -t codereview main..feature-branch

CODEREVIEW_LOCAL="$1" CODEREVIEW_REMOTE="$2" \
  exec nvim -c "lua require('codereview').difftool(vim.env.CODEREVIEW_LOCAL, vim.env.CODEREVIEW_REMOTE)"
